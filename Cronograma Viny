function initSortable(){
  document.querySelectorAll('.items-list').forEach(l=>{
    if(l._s)l._s.destroy();
    l._s=Sortable.create(l,{group:'schedule',animation:150,handle:'.drag-handle',ghostClass:'sortable-ghost',chosenClass:'sortable-chosen',onEnd:saveSchedule});
  });
}
function saveSchedule(){
  const map={};
  document.querySelectorAll('.items-list').forEach(l=>{
    const items=[];
    l.querySelectorAll('.sched-item').forEach(el=>items.push({id:el.dataset.id,dot:el.dataset.dot,title:el.dataset.title,sub:el.dataset.sub,badge:el.dataset.badge,badgeCls:el.dataset.badgeCls}));
