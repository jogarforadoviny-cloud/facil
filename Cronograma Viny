function getStreak(){return parseInt(localStorage.getItem('streakDays')||'0');}
function getLastStudyDay(){return localStorage.getItem('lastStudyDay')||'';}
function markStudyToday(){
  const today=todayStr(),last=getLastStudyDay();
  if(today===last)return;
  const yd=new Date();yd.setDate(yd.getDate()-1);
  const yStr=`${yd.getFullYear()}-${String(yd.getMonth()+1).padStart(2,'0')}-${String(yd.getDate()).padStart(2,'0')}`;
  const streak=(last===yStr)?getStreak()+1:1;
  localStorage.setItem('streakDays',String(streak));
  localStorage.setItem('lastStudyDay',today);
  renderStreak();
  const studied=getStudiedDays();
  if(!studied.includes(today)){studied.push(today);localStorage.setItem('studiedDays',JSON.stringify(studied));}
}
function renderStreak(){document.getElementById('streakCount').textContent=getStreak();}
function getStudiedDays(){return JSON.parse(localStorage.getItem('studiedDays')||'[]');}
function getStreakDays(){
  const streak=getStreak(),last=getLastStudyDay();
  if(!last||!streak)return[];
  const days=[];
  const base=new Date(last+'T12:00:00');
  for(let i=0;i<streak;i++){
    const d=new Date(base);d.setDate(d.getDate()-i);
    days.push(`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`);
  }
  return days;
}
