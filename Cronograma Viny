let transDir='pt-jp';
function setTransDir(dir){
  transDir=dir;
  ['dirPtJp','dirJpPt','dirJpEn'].forEach(id=>document.getElementById(id).classList.remove('active'));
  const map={'pt-jp':'dirPtJp','jp-pt':'dirJpPt','jp-en':'dirJpEn'};
  document.getElementById(map[dir]).classList.add('active');
  const ph={'pt-jp':'Ex: Olá, como vai você?','jp-pt':'例: こんにちは、元気ですか？','jp-en':'例: こんにちは、元気ですか？'};
  document.getElementById('jpTransInput').placeholder=ph[dir];
  document.getElementById('jpTransText').textContent='A tradução aparecerá aqui...';
  document.getElementById('jpTransText').style.color='var(--muted)';
  document.getElementById('jpTransText').style.fontSize='.75rem';
}

function getApiKey(){return localStorage.getItem('claude_api_key')||'';}
function openApiKeyPrompt(){
  const cur=getApiKey();
  const k=prompt('Cole sua Anthropic API Key (sk-ant-...):\n\nEla será salva só no seu navegador (localStorage).',cur);
  if(k&&k.trim()){localStorage.setItem('claude_api_key',k.trim());alert('✅ API Key salva!');}
}

async function doTranslate(){
  const inp=document.getElementById('jpTransInput').value.trim();
  if(!inp)return;
  const apiKey=getApiKey();
  if(!apiKey){
    if(confirm('Para usar o tradutor, configure sua API Key da Anthropic.\n\nConfigurar agora?')){openApiKeyPrompt();}
    return;
  }
  const btn=document.getElementById('jpTransBtn');
  const resultEl=document.getElementById('jpTransText');
  btn.disabled=true;
  resultEl.className='jp-trans-result-text loading';
  resultEl.textContent='Traduzindo...';

  const prompts={
    'pt-jp':`Traduza o seguinte texto do Português para o Japonês. Responda APENAS com: 1) a tradução em japonês (kanji+kana), 2) a romanização (romaji) entre parênteses, 3) uma linha em branco, 4) uma explicação curtíssima das palavras-chave. Texto: "${inp}"`,
    'jp-pt':`Traduza o seguinte texto do Japonês para o Português Brasileiro. Responda com: 1) a tradução em português, 2) uma linha em branco, 3) a leitura (romaji) do original, 4) significado literal de palavras-chave. Texto: "${inp}"`,
    'jp-en':`Translate the following Japanese text to English. Respond with: 1) the English translation, 2) blank line, 3) romanization (romaji) of the original, 4) brief note on key vocabulary. Text: "${inp}"`
  };

  try{
    const resp=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json','x-api-key':apiKey,'anthropic-version':'2023-06-01'},
      body:JSON.stringify({model:'claude-haiku-20240307',max_tokens:400,messages:[{role:'user',content:prompts[transDir]}]})
    });
    if(!resp.ok){
      const err=await resp.json();
      throw new Error(err.error?.message||'Erro na API');
    }
    const data=await resp.json();
    const text=data.content?.[0]?.text||'Sem resposta.';
    resultEl.className='jp-trans-result-text';
    resultEl.style.color='';
    resultEl.style.fontSize='';
    const lines=text.trim().split('\n');
    resultEl.innerHTML=lines.map((l,i)=>i===0?`<span style="font-size:1.1rem;color:#a78bfa;font-family:'Noto Sans JP',serif">${l}</span>`:`<span style="font-size:.73rem;color:var(--muted2);display:block;margin-top:${l===''?'6':2}px">${l}</span>`).join('');
    if(transDir==='pt-jp'){
      const speakBtn=document.createElement('button');
      speakBtn.className='jp-trans-speak';speakBtn.textContent='🔊 Ouvir';
      speakBtn.onclick=()=>speakJP(lines[0]);
      document.getElementById('jpTransResult').appendChild(speakBtn);
    }
  } catch(e){
    resultEl.className='jp-trans-result-text';
    resultEl.style.color='#f87171';
    resultEl.style.fontSize='.8rem';
    resultEl.textContent='Erro: '+(e.message||'Verifique sua API Key.');
  } finally{
    btn.disabled=false;
  }
} 

document.addEventListener('DOMContentLoaded',()=>{
  const inp=document.getElementById('jpTransInput');
  if(inp)inp.addEventListener('keydown',e=>{if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();doTranslate();}});
});

