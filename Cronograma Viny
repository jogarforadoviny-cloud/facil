<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sistema de Estudos ✦</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&family=Noto+Sans+KR:wght@400;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.2/Sortable.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.2/dist/confetti.browser.min.js"></script>
<style>
:root{
  --bg:#060b18;--surface:#0d1420;--surface2:#0a1020;--border:#1a2640;--border2:#283550;
  --text:#e2e8f0;--muted:#64748b;--muted2:#475569;
  --blue:#3b82f6;--purple:#a855f7;--green:#10b981;--amber:#f59e0b;--red:#ef4444;--pink:#f43f5e;
  --blue-dim:#1a2e4f;--purple-dim:#2e1650;--green-dim:#052e22;--amber-dim:#3a1500;
  --streak-color:#fb923c;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--text);display:flex;min-height:100vh;overflow:hidden;}

/* ── SIDEBAR ── */
.sidebar{width:242px;background:linear-gradient(180deg,#06091a,#080c1c);height:100vh;border-right:1px solid var(--border);position:sticky;top:0;flex-shrink:0;display:flex;flex-direction:column;overflow:hidden;}
.sidebar-inner{display:flex;flex-direction:column;gap:4px;padding:12px 11px;height:100%;overflow-y:auto;scrollbar-width:thin;scrollbar-color:#1a2640 transparent;}
.sidebar-logo{text-align:center;padding:3px 0 8px;border-bottom:1px solid var(--border);margin-bottom:2px;}
.sidebar-logo span{font-size:.88rem;font-weight:800;color:#60a5fa;letter-spacing:1px;}

/* Profile */
.profile-bar{background:linear-gradient(135deg,#0d1a30,#111d35);border:1px solid var(--border);border-radius:11px;padding:9px 11px;display:flex;align-items:center;gap:9px;}
.avatar{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#3b82f6,#7c3aed);display:flex;align-items:center;justify-content:center;font-size:1rem;font-weight:800;color:#fff;flex-shrink:0;cursor:pointer;border:2px solid #3b82f630;transition:.2s;user-select:none;}
.avatar:hover{border-color:#60a5fa;}
.profile-info{flex:1;min-width:0;}
.profile-name{font-size:.8rem;font-weight:700;color:#e2e8f0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:pointer;}
.profile-name:hover{color:#60a5fa;}
.profile-name-input{background:none;border:none;border-bottom:1px dashed #3b82f6;color:#e2e8f0;font-size:.8rem;font-weight:700;outline:none;width:100%;padding:1px 0;}
.profile-title{font-size:.6rem;color:var(--muted2);margin-top:1px;}

/* Gamebar */
.gamebar{background:linear-gradient(135deg,#0d1a30,#111d35);border:1px solid var(--border);border-radius:11px;padding:9px 11px;}
.gamebar-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:7px;}
.streak-badge{display:flex;align-items:center;gap:4px;font-size:.76rem;font-weight:800;color:var(--streak-color);}
.level-badge{font-size:.63rem;font-weight:700;color:#60a5fa;background:#1a2e4f;padding:2px 7px;border-radius:20px;border:1px solid #3b82f630;}
.xp-bar-wrap{background:#0a1020;border-radius:20px;height:7px;overflow:hidden;}
.xp-bar-fill{height:100%;background:linear-gradient(90deg,#f59e0b,#fbbf24);border-radius:20px;transition:width .5s cubic-bezier(.4,0,.2,1);}
.xp-label{font-size:.58rem;color:var(--muted);margin-top:3px;text-align:right;}

/* Nav */
nav{display:flex;flex-direction:column;gap:3px;}
.nav-btn{width:100%;padding:8px 10px;background:#0d1520;border:1px solid var(--border);color:#94a3b8;border-radius:8px;cursor:pointer;transition:.2s;font-weight:600;text-align:left;display:flex;align-items:center;gap:7px;font-size:.8rem;}
.nav-btn:hover{background:var(--border);color:var(--text);}
.nav-btn.active{background:var(--border);border-color:#60a5fa;color:#60a5fa;box-shadow:inset 0 0 12px rgba(96,165,250,.15);}

/* Frase */
.frase-box{background:linear-gradient(135deg,#0d1a2d,#0a1628);border:1px solid var(--blue-dim);border-radius:9px;padding:9px;}
.frase-label{font-size:.56rem;text-transform:uppercase;letter-spacing:2px;color:#1e3a5f;margin-bottom:4px;}
.frase-text{font-size:.67rem;color:#93c5fd;line-height:1.5;font-style:italic;}
.frase-author{font-size:.57rem;color:var(--border2);margin-top:3px;text-align:right;}
.frase-refresh{background:none;border:none;color:var(--muted);cursor:pointer;font-size:.6rem;margin-top:3px;display:block;width:100%;text-align:right;transition:.2s;}
.frase-refresh:hover{color:#60a5fa;}

/* ── YOUTUBE FLUTUANTE ── */
.yt-float{
  position:fixed;
  bottom:18px;
  left:258px;
  z-index:1500;
  width:270px;
  background:linear-gradient(135deg,#08101e,#0a1220);
  border:1px solid var(--border2);
  border-radius:13px;
  overflow:hidden;
  box-shadow:0 8px 32px rgba(0,0,0,.7);
  transition:all .3s ease;
}
.yt-float.collapsed .yt-float-body{max-height:0;overflow:hidden;}
.yt-float-header{
  background:linear-gradient(90deg,#1a0000,#2a0a0a);
  padding:7px 10px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  cursor:pointer;
  user-select:none;
  border-bottom:1px solid #ff000022;
}
.yt-float-title{font-size:.7rem;font-weight:800;color:#ff6b6b;display:flex;align-items:center;gap:6px;}
.yt-float-title::before{content:'▶';font-size:.6rem;background:#ff0000;color:#fff;padding:2px 5px;border-radius:4px;}
.yt-float-toggle{background:none;border:none;cursor:pointer;color:#ff6b6b;font-size:.75rem;padding:2px 5px;border-radius:4px;transition:.2s;}
.yt-float-toggle:hover{background:#ff000022;}
.yt-float-body{max-height:400px;transition:max-height .3s ease;overflow:hidden;}

/* Search bar */
.yt-search-area{padding:8px 9px 5px;}
.yt-search-row{display:flex;gap:5px;margin-bottom:5px;}
.yt-search-input{flex:1;background:#0a1520;border:1px solid var(--border2);color:var(--text);padding:6px 9px;border-radius:7px;font-size:.68rem;outline:none;transition:border .2s;}
.yt-search-input:focus{border-color:#ff0000;}
.yt-search-btn{background:#ff0000;border:none;color:#fff;padding:6px 10px;border-radius:7px;cursor:pointer;font-size:.68rem;font-weight:700;white-space:nowrap;transition:.2s;}
.yt-search-btn:hover{background:#cc0000;}
.yt-url-row{display:flex;gap:5px;}
.yt-url-input{flex:1;background:#0a1520;border:1px solid var(--border2);color:var(--text);padding:5px 8px;border-radius:6px;font-size:.6rem;outline:none;}
.yt-url-input:focus{border-color:#ff0000;}
.yt-load-btn{background:#333;border:1px solid var(--border2);color:#ccc;padding:5px 8px;border-radius:6px;cursor:pointer;font-size:.6rem;font-weight:700;}
.yt-load-btn:hover{background:#555;color:#fff;}

/* Search results */
.yt-results{max-height:160px;overflow-y:auto;scrollbar-width:thin;scrollbar-color:#1a2640 transparent;padding:0 7px 5px;}
.yt-result-item{display:flex;gap:7px;padding:5px;border-radius:7px;cursor:pointer;transition:.15s;border:1px solid transparent;margin-bottom:3px;}
.yt-result-item:hover{background:#1a2640;border-color:#283550;}
.yt-result-thumb{width:56px;height:36px;border-radius:4px;object-fit:cover;flex-shrink:0;background:#0a1520;}
.yt-result-info{flex:1;min-width:0;}
.yt-result-title{font-size:.62rem;color:#e2e8f0;font-weight:600;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;line-height:1.3;}
.yt-result-ch{font-size:.54rem;color:var(--muted2);margin-top:2px;}
.yt-no-results{font-size:.65rem;color:var(--muted);text-align:center;padding:10px 0;}
.yt-searching{font-size:.62rem;color:#60a5fa;text-align:center;padding:8px 0;display:flex;align-items:center;justify-content:center;gap:5px;}
.yt-spinner{width:10px;height:10px;border:2px solid #1a2640;border-top-color:#60a5fa;border-radius:50%;animation:spin .7s linear infinite;}
@keyframes spin{to{transform:rotate(360deg)}}

/* Player */
#ytPlayerDiv{width:100%;}
.yt-player-wrap{padding:0 7px 5px;}
.yt-controls{display:none;justify-content:center;gap:5px;padding:4px 7px;}
.yt-controls.visible{display:flex;}
.yt-ctrl-btn{background:var(--border);border:1px solid var(--border2);color:#94a3b8;padding:4px 10px;border-radius:5px;cursor:pointer;font-size:.64rem;font-weight:700;transition:.2s;}
.yt-ctrl-btn:hover{border-color:#ff0000;color:#fca5a5;}
.yt-now-playing{font-size:.56rem;color:var(--muted2);padding:0 9px 5px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}

/* ── CONTENT ── */
.content{flex:1;padding:20px 24px;overflow-y:auto;height:100vh;padding-bottom:100px;}
.hidden{display:none!important;}
.page-header{text-align:center;margin-bottom:18px;}
.page-header h1{font-size:1.55rem;font-weight:800;background:linear-gradient(135deg,#60a5fa,#a78bfa,#34d399);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:3px;}
.page-header p{color:var(--muted);font-size:.8rem;}

/* Suggestion */
.suggestion-box{background:linear-gradient(135deg,#1a1000,#1c1400);border:1px solid #92400e55;border-radius:11px;padding:11px 15px;margin-bottom:16px;max-width:1200px;margin-left:auto;margin-right:auto;display:flex;align-items:flex-start;gap:9px;}
.suggestion-box.hidden-box{display:none;}
.sug-icon{font-size:1.2rem;flex-shrink:0;}
.sug-content{flex:1;}
.sug-title{font-size:.7rem;font-weight:800;color:#fcd34d;text-transform:uppercase;letter-spacing:1px;margin-bottom:3px;}
.sug-text{font-size:.77rem;color:#fde68a;line-height:1.5;}
.sug-dismiss{background:none;border:1px solid #92400e55;color:#92400e;padding:2px 9px;border-radius:5px;cursor:pointer;font-size:.6rem;margin-top:5px;transition:.2s;}
.sug-dismiss:hover{border-color:#f59e0b;color:#f59e0b;}

/* ── CRONOGRAMA ── */
.legend{display:flex;flex-wrap:wrap;gap:6px;justify-content:center;margin-bottom:16px;}
.legend-item{display:flex;align-items:center;gap:4px;font-size:.7rem;color:#94a3b8;background:var(--border);padding:3px 8px;border-radius:20px;}
.legend-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.sched-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(248px,1fr));gap:10px;max-width:1200px;margin:0 auto;}
.day-card{background:var(--surface);border-radius:12px;overflow:hidden;border:1px solid var(--border);transition:box-shadow .2s;}
.day-card:hover{box-shadow:0 4px 24px rgba(0,0,0,.5);}
.day-header{padding:9px 13px;font-weight:700;font-size:.85rem;display:flex;align-items:center;justify-content:space-between;color:#fff;}
.day-add-btn{background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);color:#fff;border-radius:5px;cursor:pointer;font-size:.72rem;font-weight:700;padding:2px 7px;transition:.2s;}
.day-add-btn:hover{background:rgba(255,255,255,.3);}
.seg .day-header{background:linear-gradient(90deg,#1d4ed8,#1e40af);}
.ter .day-header{background:linear-gradient(90deg,#7c3aed,#6d28d9);}
.qua .day-header{background:linear-gradient(90deg,#0f766e,#0d6b62);}
.qui .day-header{background:linear-gradient(90deg,#b45309,#92400e);}
.sex .day-header{background:linear-gradient(90deg,#be123c,#9f1239);}
.sab .day-header{background:linear-gradient(90deg,#334155,#1e293b);}
.dom .day-header{background:linear-gradient(90deg,#0e7490,#0c677f);}
.items-list{min-height:32px;}
.sched-item{padding:7px 12px;border-top:1px solid var(--surface2);display:flex;align-items:center;gap:7px;cursor:grab;user-select:none;transition:background .15s;}
.sched-item:active{cursor:grabbing;}
.sched-item:hover{background:#ffffff08;}
.sched-item.sortable-ghost{opacity:.3;background:#60a5fa22;}
.sched-item.sortable-chosen{background:#60a5fa11;box-shadow:inset 3px 0 0 #60a5fa;}
.drag-handle{color:var(--border2);font-size:.72rem;cursor:grab;flex-shrink:0;}
.dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.item-text{flex:1;}
.item-title{font-size:.8rem;font-weight:600;color:#f1f5f9;}
.item-sub{font-size:.68rem;color:var(--muted2);margin-top:1px;}
.badge{font-size:.61rem;padding:2px 6px;border-radius:20px;font-weight:700;white-space:nowrap;}
.c-bb{background:#3b82f6}.c-idiom{background:#a855f7}.c-facul{background:#10b981}.c-math{background:#f59e0b}.c-custom{background:#64748b}
.b-bb{background:var(--blue-dim);color:#93c5fd}.b-idiom{background:var(--purple-dim);color:#d8b4fe}.b-facul{background:var(--green-dim);color:#6ee7b7}.b-math{background:var(--amber-dim);color:#fcd34d}.b-april{background:#1a2e1a;color:#86efac;font-style:italic}.b-custom{background:#1e293b;color:#94a3b8}
.sched-reset{display:block;margin:13px auto 0;background:none;border:1px solid var(--border2);color:var(--muted);padding:6px 15px;border-radius:7px;cursor:pointer;font-size:.72rem;transition:.2s;}
.sched-reset:hover{border-color:var(--red);color:var(--red);}

/* ── CONTEXT MENU ── */
.ctx-menu{position:fixed;background:#0d1520;border:1px solid var(--border2);border-radius:10px;padding:5px;z-index:9999;box-shadow:0 8px 32px rgba(0,0,0,.7);min-width:155px;animation:ctxIn .12s ease;}
@keyframes ctxIn{from{opacity:0;transform:scale(.93)}to{opacity:1;transform:scale(1)}}
.ctx-title{padding:6px 13px 3px;font-size:.7rem;color:var(--muted);font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:175px;}
.ctx-sep{height:1px;background:var(--border);margin:3px 0;}
.ctx-item{padding:8px 13px;border-radius:6px;cursor:pointer;font-size:.78rem;font-weight:600;display:flex;align-items:center;gap:7px;transition:.15s;}
.ctx-item.danger{color:#f87171;}
.ctx-item.danger:hover{background:#4c051930;}

/* ── TRACKER ── */
.tracker-wrap{max-width:1100px;margin:auto;background:var(--surface);padding:20px;border-radius:13px;border:1px solid var(--border);}
.tracker-top-bar{display:flex;justify-content:space-between;align-items:center;margin-bottom:15px;flex-wrap:wrap;gap:9px;}
.week-controls{display:flex;align-items:center;gap:11px;}
.week-select{background:var(--border);color:#60a5fa;border:1px solid #60a5fa;padding:6px 14px;border-radius:7px;font-weight:700;font-size:.9rem;}
.btn-add-materia{background:linear-gradient(135deg,#34d399,#10b981);color:#064e3b;border:none;padding:7px 13px;border-radius:7px;font-weight:800;cursor:pointer;font-size:.76rem;}
table.tracker-table{width:100%;border-collapse:collapse;}
table.tracker-table th{text-align:left;padding:8px;color:var(--muted);font-size:.7rem;text-transform:uppercase;border-bottom:1px solid var(--border);}
table.tracker-table td{padding:7px 8px;border-top:1px solid var(--border);vertical-align:top;}
.aula-block{background:var(--surface2);border:1px solid var(--border);border-radius:9px;padding:8px;margin-bottom:5px;}
.aula-header{display:flex;align-items:center;gap:6px;margin-bottom:5px;}
.aula-num{font-size:.58rem;text-transform:uppercase;letter-spacing:2px;color:var(--muted2);white-space:nowrap;min-width:40px;}
.aula-chk{accent-color:#60a5fa;transform:scale(1.2);cursor:pointer;flex-shrink:0;}
.aula-input{flex:1;background:var(--bg);border:1px solid var(--border2);color:var(--text);padding:5px 8px;border-radius:5px;font-size:.78rem;outline:none;transition:border .2s;}
.aula-input:focus{border-color:#60a5fa;}
.aula-rm{background:none;border:none;color:var(--muted2);cursor:pointer;font-size:.72rem;flex-shrink:0;padding:2px 4px;transition:.2s;}
.aula-rm:hover{color:var(--red);}
.aula-rev{display:flex;gap:10px;align-items:center;flex-wrap:wrap;padding-left:2px;}
.aula-rev label{display:flex;align-items:center;gap:4px;font-size:.67rem;color:#94a3b8;font-weight:700;cursor:pointer;}
.aula-rev input[type=checkbox]{accent-color:#a78bfa;transform:scale(1.1);}
.btn-add-aula{background:none;border:1px dashed var(--border2);color:var(--muted);padding:4px 10px;border-radius:6px;cursor:pointer;font-size:.68rem;transition:.2s;width:100%;text-align:center;margin-top:2px;}
.btn-add-aula:hover{border-color:#60a5fa;color:#60a5fa;}
.mat-name-cell{display:flex;align-items:center;gap:5px;}
.btn-rm-mat{background:none;border:none;color:var(--muted2);cursor:pointer;font-size:.72rem;opacity:0;transition:.2s;}
tr:hover .btn-rm-mat{opacity:1;}
.btn-rm-mat:hover{color:var(--red);}
.btn-save{background:linear-gradient(135deg,#34d399,#10b981);color:#064e3b;border:none;padding:10px 24px;border-radius:7px;font-weight:800;cursor:pointer;margin-top:14px;float:right;}
.save-msg{display:inline-block;margin-top:17px;font-size:.76rem;color:#34d399;opacity:0;transition:opacity .4s;}
.save-msg.show{opacity:1;}
.clearfix{overflow:hidden;}

/* ── FLASH ANIMATIONS ── */
.xp-flash{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:linear-gradient(135deg,#f59e0b,#fbbf24);color:#422006;padding:11px 26px;border-radius:50px;font-weight:800;font-size:1.15rem;z-index:9999;pointer-events:none;animation:xpFlash .9s ease forwards;}
@keyframes xpFlash{0%{opacity:0;transform:translate(-50%,-60%) scale(.7)}30%{opacity:1;transform:translate(-50%,-50%) scale(1.1)}70%{opacity:1;transform:translate(-50%,-50%) scale(1)}100%{opacity:0;transform:translate(-50%,-40%) scale(.9)}}
.levelup-flash{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:linear-gradient(135deg,#7c3aed,#a855f7);color:#fff;padding:16px 34px;border-radius:15px;font-weight:800;font-size:1.3rem;z-index:10000;text-align:center;pointer-events:none;box-shadow:0 0 60px #a855f755;animation:lvlFlash 1.5s ease forwards;}
@keyframes lvlFlash{0%{opacity:0;transform:translate(-50%,-60%) scale(.6)}25%{opacity:1;transform:translate(-50%,-50%) scale(1.05)}75%{opacity:1;transform:translate(-50%,-50%) scale(1)}100%{opacity:0;transform:translate(-50%,-40%) scale(.95)}}

/* ── IDIOMAS ── */
.lab-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:15px;max-width:1200px;margin:0 auto;}
.lab-grid-full{grid-column:1/-1;}
.kanji-card{background:linear-gradient(135deg,#0d1117,var(--surface));border:1px solid #292524;border-radius:15px;padding:20px;text-align:center;position:relative;overflow:hidden;}
.kanji-card::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,#7c3aed18,transparent 65%);pointer-events:none;}
.kanji-badge{display:inline-block;font-size:.61rem;text-transform:uppercase;letter-spacing:3px;color:#7c3aed;background:#7c3aed18;padding:3px 13px;border-radius:20px;margin-bottom:10px;border:1px solid #7c3aed33;}
.kanji-symbol{font-family:'Noto Sans JP',serif;font-size:5rem;line-height:1;color:#f1f5f9;margin:6px 0;text-shadow:0 0 40px #7c3aed55;}
.kanji-info{display:flex;justify-content:center;gap:26px;margin-top:12px;flex-wrap:wrap;}
.kanji-item label{font-size:.58rem;text-transform:uppercase;letter-spacing:2px;color:var(--muted2);display:block;margin-bottom:3px;}
.kanji-item .val{font-size:.9rem;font-weight:700;color:#a78bfa;font-family:'Noto Sans JP',serif;}
.kanji-item .roma{font-size:.74rem;color:var(--muted);font-style:italic;margin-top:2px;}
.kanji-counter{font-size:.65rem;color:var(--muted);margin-top:6px;}
.kanji-nav{display:flex;justify-content:center;gap:8px;margin-top:12px;flex-wrap:wrap;}
.kanji-nav button{background:var(--border);border:1px solid var(--border2);color:#94a3b8;padding:5px 15px;border-radius:7px;cursor:pointer;font-size:.75rem;transition:.2s;}
.kanji-nav button:hover{border-color:#7c3aed;color:#a78bfa;}
.kanji-add-btn{background:linear-gradient(135deg,#7c3aed,#a855f7);border:none;color:#fff;padding:5px 15px;border-radius:7px;cursor:pointer;font-size:.75rem;font-weight:700;}
.kana-section{background:var(--surface);border:1px solid var(--border);border-radius:13px;padding:15px;}
.kana-section h3{font-size:.74rem;text-transform:uppercase;letter-spacing:2px;color:#60a5fa;margin-bottom:4px;}
.kana-toggle{display:flex;gap:5px;margin-bottom:11px;}
.kana-toggle-btn{background:var(--surface2);border:1px solid var(--border2);color:var(--muted);padding:4px 11px;border-radius:6px;cursor:pointer;font-size:.72rem;font-weight:700;transition:.2s;}
.kana-toggle-btn.active{background:var(--blue-dim);border-color:#60a5fa;color:#60a5fa;}
.kana-table{width:100%;border-collapse:collapse;font-size:.74rem;}
.kana-table th{background:#0d1520;color:var(--muted2);padding:4px 2px;font-size:.6rem;text-align:center;}
.kana-table td{text-align:center;padding:4px 2px;border:1px solid #0d1520;transition:background .15s;cursor:pointer;border-radius:4px;}
.kana-table td:hover{background:#60a5fa22;border-color:#60a5fa55;}
.kana-table td.playing{background:#60a5fa33;border-color:#60a5fa;animation:kanaPulse .4s ease;}
@keyframes kanaPulse{0%{transform:scale(1)}50%{transform:scale(1.15)}100%{transform:scale(1)}}
.kana-char{font-family:'Noto Sans JP','Noto Sans KR',serif;font-size:1rem;display:block;color:#f1f5f9;}
.kana-roma{font-size:.56rem;color:var(--muted2);}
.kana-empty{color:var(--border);cursor:default!important;}
.kana-empty:hover{background:transparent!important;border-color:#0d1520!important;}

/* ── FORMADOR DE PALAVRAS JP ── */
.jp-translator{background:var(--surface);border:1px solid var(--border);border-radius:13px;padding:15px;margin-top:0;}
.jp-translator h3{font-size:.74rem;text-transform:uppercase;letter-spacing:2px;color:#7c3aed;margin-bottom:12px;display:flex;align-items:center;gap:6px;}
.jp-translator h3 span{font-size:.6rem;background:#7c3aed22;border:1px solid #7c3aed44;padding:2px 7px;border-radius:10px;color:#a78bfa;text-transform:none;letter-spacing:0;}
.jp-trans-row{display:flex;gap:7px;margin-bottom:9px;align-items:stretch;}
.jp-trans-dir{display:flex;gap:5px;margin-bottom:8px;}
.jp-trans-dir-btn{flex:1;padding:6px;border-radius:7px;border:1px solid var(--border2);background:var(--surface2);color:var(--muted);cursor:pointer;font-size:.68rem;font-weight:700;transition:.2s;text-align:center;}
.jp-trans-dir-btn.active{background:var(--purple-dim);border-color:#7c3aed;color:#a78bfa;}
.jp-trans-input{flex:1;background:#0a1020;border:1px solid var(--border2);color:var(--text);padding:9px 12px;border-radius:8px;font-size:.9rem;outline:none;font-family:'Noto Sans JP','Segoe UI',sans-serif;transition:border .2s;}
.jp-trans-input:focus{border-color:#7c3aed;}
.jp-trans-btn{background:linear-gradient(135deg,#7c3aed,#a855f7);border:none;color:#fff;padding:9px 14px;border-radius:8px;cursor:pointer;font-size:.75rem;font-weight:800;white-space:nowrap;transition:.2s;}
.jp-trans-btn:hover{opacity:.85;}
.jp-trans-btn:disabled{opacity:.4;cursor:not-allowed;}
.jp-trans-result{background:#0a1020;border:1px solid var(--border2);border-radius:9px;padding:11px 13px;min-height:52px;position:relative;}
.jp-trans-result-text{font-size:.9rem;color:#a78bfa;font-family:'Noto Sans JP','Segoe UI',sans-serif;line-height:1.6;word-break:break-word;}
.jp-trans-result-text.loading{color:var(--muted);font-size:.75rem;display:flex;align-items:center;gap:7px;}
.jp-trans-result-text.loading::before{content:'';display:inline-block;width:10px;height:10px;border:2px solid #283550;border-top-color:#7c3aed;border-radius:50%;animation:spin .7s linear infinite;}
.jp-trans-speak{position:absolute;right:8px;top:8px;background:none;border:1px solid var(--border2);color:var(--muted);padding:3px 8px;border-radius:5px;cursor:pointer;font-size:.62rem;transition:.2s;}
.jp-trans-speak:hover{border-color:#7c3aed;color:#a78bfa;}
.jp-trans-examples{margin-top:7px;}
.jp-trans-example{font-size:.65rem;color:var(--muted2);border-top:1px solid var(--border);padding-top:5px;margin-top:5px;line-height:1.5;}

/* ── HANGUL COMPLETO ── */
.hangul-lab{background:var(--surface);border:1px solid var(--border);border-radius:13px;padding:15px;}
.hangul-lab-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;}
.hangul-lab-header h3{font-size:.74rem;text-transform:uppercase;letter-spacing:2px;color:#f43f5e;}
.hangul-add-btn{background:linear-gradient(135deg,#f43f5e,#e11d48);border:none;color:#fff;padding:4px 11px;border-radius:6px;cursor:pointer;font-size:.7rem;font-weight:700;}
.hangul-add-btn:hover{opacity:.85;}
.hangul-cols{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:8px;}
.hangul-section-label{font-size:.62rem;text-transform:uppercase;letter-spacing:2px;color:var(--muted);display:block;margin-bottom:6px;}
.hangul-keys{display:flex;flex-wrap:wrap;gap:4px;min-height:28px;}
.hangul-key{font-family:'Noto Sans KR',serif;padding:4px 5px;background:var(--surface2);border:1px solid var(--border2);border-radius:7px;cursor:pointer;transition:.2s;color:#f1f5f9;display:flex;flex-direction:column;align-items:center;min-width:36px;user-select:none;}
.hangul-key .hk-main{font-size:1rem;line-height:1;}
.hangul-key .hk-rom{font-size:.46rem;color:var(--muted);line-height:1;margin-top:1px;font-family:'Segoe UI',sans-serif;}
.hangul-key:hover{border-color:#f43f5e;background:#4c0519;color:#fda4af;}
.hangul-key.selected{background:#4c0519;border-color:#f43f5e;color:#fda4af;box-shadow:0 0 10px #f43f5e33;}
.hangul-result{text-align:center;padding:13px;background:linear-gradient(135deg,#1a0008,#0d1520);border:1px solid #f43f5e33;border-radius:11px;position:relative;overflow:hidden;margin-top:9px;}
.hangul-result::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,#f43f5e18,transparent 65%);}
.hangul-syllable{font-family:'Noto Sans KR',serif;font-size:4rem;color:#f1f5f9;text-shadow:0 0 30px #f43f5e55;line-height:1;position:relative;z-index:1;}
.hangul-combo-label{font-size:.63rem;color:var(--muted2);margin-top:6px;letter-spacing:1px;text-transform:uppercase;position:relative;z-index:1;}
.hangul-actions{display:flex;gap:7px;justify-content:center;margin-top:8px;position:relative;z-index:1;flex-wrap:wrap;}
.hangul-clear{background:none;border:1px solid var(--border2);color:var(--muted);padding:4px 11px;border-radius:6px;cursor:pointer;font-size:.7rem;transition:.2s;}
.hangul-clear:hover{border-color:#f43f5e;color:#f43f5e;}
.hangul-speak{background:linear-gradient(135deg,#f43f5e,#e11d48);border:none;color:#fff;padding:4px 13px;border-radius:6px;cursor:pointer;font-size:.7rem;font-weight:700;}
.hangul-speak:disabled{opacity:.35;cursor:not-allowed;}
.speech-status{font-size:.58rem;color:var(--muted2);margin-top:4px;position:relative;z-index:1;}
.hangul-test-panel{margin-top:9px;background:var(--surface2);border:1px solid var(--border2);border-radius:9px;padding:9px;position:relative;z-index:1;}
.hangul-test-panel label{font-size:.61rem;text-transform:uppercase;letter-spacing:1px;color:var(--muted);display:block;margin-bottom:5px;}
.hangul-test-row{display:flex;gap:5px;}
.hangul-test-input{flex:1;background:var(--bg);border:1px solid var(--border2);color:var(--text);padding:5px 8px;border-radius:6px;font-size:.85rem;outline:none;font-family:'Noto Sans KR',serif;}
.hangul-test-input:focus{border-color:#f43f5e;}
.hangul-test-speak{background:linear-gradient(135deg,#f43f5e,#e11d48);border:none;color:#fff;padding:5px 12px;border-radius:6px;cursor:pointer;font-size:.7rem;font-weight:700;}
.hangul-test-preview{font-family:'Noto Sans KR',serif;font-size:2rem;color:#fda4af;text-align:center;margin-top:6px;min-height:38px;text-shadow:0 0 20px #f43f5e55;}

/* ── CALENDAR ── */
.calendar-wrap{max-width:1100px;margin:0 auto;}
.cal-nav{display:flex;justify-content:center;align-items:center;gap:16px;margin-bottom:18px;}
.cal-nav button{background:var(--border);border:1px solid var(--border2);color:#94a3b8;padding:6px 16px;border-radius:7px;cursor:pointer;font-size:.8rem;font-weight:700;transition:.2s;}
.cal-nav button:hover{border-color:#60a5fa;color:#60a5fa;}
.cal-month-title{font-size:1.15rem;font-weight:800;color:#e2e8f0;min-width:210px;text-align:center;}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:5px;}
.cal-dayname{text-align:center;font-size:.66rem;color:var(--muted2);font-weight:700;text-transform:uppercase;padding:5px 0;}
.cal-cell{min-height:110px;border-radius:10px;display:flex;flex-direction:column;align-items:stretch;font-size:.8rem;font-weight:600;background:var(--surface);border:1px solid var(--border);transition:.2s;overflow:hidden;cursor:default;}
.cal-cell.empty{background:transparent;border-color:transparent;}
.cal-cell-num{padding:5px 7px;font-size:.78rem;font-weight:700;color:#94a3b8;text-align:right;}
.cal-cell.today .cal-cell-num{color:#60a5fa;}
.cal-cell.today{border-color:#60a5fa;box-shadow:0 0 10px #60a5fa22;}
.cal-cell.studied{background:linear-gradient(160deg,#052e22,#062e24);border-color:#10b981;}
.cal-cell.studied .cal-cell-num{color:#34d399;}
.cal-cell.streak-day{background:linear-gradient(160deg,#3a1000,#451400);border-color:#f59e0b;}
.cal-cell.streak-day .cal-cell-num{color:#fcd34d;}
.cal-items{padding:2px 4px 4px;display:flex;flex-direction:column;gap:2px;flex:1;overflow:hidden;}
.cal-item-chip{font-size:.48rem;background:#1a2640;color:#94a3b8;border-radius:3px;padding:1px 4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.5;}
.cal-item-chip.chip-bb{background:#1a2e4f;color:#93c5fd;}
.cal-item-chip.chip-idiom{background:#2e1650;color:#d8b4fe;}
.cal-item-chip.chip-facul{background:#052e22;color:#6ee7b7;}
.cal-item-chip.chip-math{background:#3a1500;color:#fcd34d;}
.cal-item-chip.chip-custom{background:#1e293b;color:#94a3b8;}
.cal-legend{display:flex;gap:12px;justify-content:center;margin-top:14px;flex-wrap:wrap;}
.cal-legend-item{display:flex;align-items:center;gap:6px;font-size:.71rem;color:#94a3b8;}
.cal-legend-dot{width:11px;height:11px;border-radius:3px;}

/* ── MODALS ── */
.modal-overlay{position:fixed;inset:0;background:#000000cc;z-index:2000;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(4px);}
.modal-box{background:#0d1520;border:1px solid var(--border2);border-radius:14px;padding:24px;width:350px;max-width:90vw;max-height:90vh;overflow-y:auto;}
.modal-box h3{font-size:.95rem;font-weight:800;color:#a78bfa;margin-bottom:14px;text-align:center;}
.modal-field{margin-bottom:10px;}
.modal-field label{font-size:.68rem;text-transform:uppercase;letter-spacing:1px;color:var(--muted);display:block;margin-bottom:4px;}
.modal-field input{width:100%;background:var(--bg);border:1px solid var(--border2);color:var(--text);padding:8px 10px;border-radius:7px;font-size:.86rem;outline:none;transition:border .2s;font-family:'Noto Sans JP',sans-serif;}
.modal-field input:focus{border-color:#7c3aed;}
.modal-actions{display:flex;gap:8px;margin-top:14px;}
.modal-cancel{flex:1;background:var(--border);border:none;color:var(--muted);padding:9px;border-radius:7px;cursor:pointer;font-weight:700;}
.modal-save{flex:2;background:linear-gradient(135deg,#7c3aed,#a855f7);border:none;color:#fff;padding:9px;border-radius:7px;cursor:pointer;font-weight:800;}
.gen-modal-overlay{position:fixed;inset:0;background:#000000cc;z-index:3000;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(4px);}
.gen-modal-box{background:#0d1520;border:1px solid var(--border2);border-radius:14px;padding:24px;width:370px;max-width:90vw;}
.gen-modal-box h3{font-size:.95rem;font-weight:800;color:#60a5fa;margin-bottom:14px;text-align:center;}
.gen-modal-box label{font-size:.68rem;text-transform:uppercase;letter-spacing:1px;color:var(--muted);display:block;margin-bottom:4px;margin-top:10px;}
.gen-modal-box input,.gen-modal-box select{width:100%;background:var(--bg);border:1px solid var(--border2);color:var(--text);padding:8px 10px;border-radius:7px;font-size:.86rem;outline:none;}
.gen-modal-box input:focus,.gen-modal-box select:focus{border-color:#60a5fa;}
.gen-modal-actions{display:flex;gap:8px;margin-top:14px;}
.gen-modal-cancel{flex:1;background:var(--border);border:none;color:var(--muted);padding:9px;border-radius:7px;cursor:pointer;font-weight:700;}
.gen-modal-save{flex:2;background:linear-gradient(135deg,#3b82f6,#1d4ed8);border:none;color:#fff;padding:9px;border-radius:7px;cursor:pointer;font-weight:800;}
.hg-modal-overlay{position:fixed;inset:0;background:#000000cc;z-index:4000;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(4px);}
.hg-modal-box{background:#0d1520;border:1px solid #f43f5e55;border-radius:14px;padding:24px;width:340px;max-width:90vw;}
.hg-modal-box h3{font-size:.95rem;font-weight:800;color:#f43f5e;margin-bottom:14px;text-align:center;}
.hg-modal-box label{font-size:.68rem;text-transform:uppercase;letter-spacing:1px;color:var(--muted);display:block;margin-bottom:4px;margin-top:10px;}
.hg-modal-box input{width:100%;background:var(--bg);border:1px solid var(--border2);color:var(--text);padding:8px 10px;border-radius:7px;font-size:1rem;outline:none;font-family:'Noto Sans KR',serif;}
.hg-modal-box input:focus{border-color:#f43f5e;}
.hg-modal-box select{width:100%;background:var(--bg);border:1px solid var(--border2);color:var(--text);padding:8px 10px;border-radius:7px;font-size:.85rem;outline:none;}
.hg-modal-actions{display:flex;gap:8px;margin-top:14px;}
.hg-modal-cancel{flex:1;background:var(--border);border:none;color:var(--muted);padding:9px;border-radius:7px;cursor:pointer;font-weight:700;}
.hg-modal-save{flex:2;background:linear-gradient(135deg,#f43f5e,#e11d48);border:none;color:#fff;padding:9px;border-radius:7px;cursor:pointer;font-weight:800;}

/* ── STICKY ── */
.sticky{position:fixed;bottom:18px;right:18px;z-index:1000;width:225px;}
.sticky-header{background:linear-gradient(135deg,#facc15,#eab308);padding:6px 10px;border-radius:9px 9px 0 0;display:flex;justify-content:space-between;align-items:center;cursor:pointer;user-select:none;}
.sticky-header span{font-size:.7rem;font-weight:800;color:#422006;}
.sticky-toggle{background:none;border:none;cursor:pointer;color:#78350f;font-size:.78rem;}
.sticky-body{background:#fef08a;border-radius:0 0 9px 9px;box-shadow:4px 6px 20px rgba(0,0,0,.5);overflow:hidden;transition:max-height .3s ease;max-height:290px;}
.sticky-body.collapsed{max-height:0;}
.sticky-textarea{width:100%;min-height:140px;resize:vertical;background:transparent;border:none;outline:none;padding:8px 10px;font-size:.76rem;color:#422006;font-family:'Segoe UI',sans-serif;line-height:1.5;}
.sticky-footer{background:#fde047;padding:3px 8px 4px;display:flex;justify-content:space-between;align-items:center;}
.sticky-saved{font-size:.56rem;color:#92400e;opacity:0;transition:opacity .4s;}
.sticky-saved.show{opacity:1;}
.sticky-clear{background:none;border:none;font-size:.56rem;color:#92400e;cursor:pointer;opacity:.6;}
.sticky-clear:hover{opacity:1;}

/* API Key notice */
.api-notice{background:linear-gradient(135deg,#1a1a00,#1c1800);border:1px solid #92400e55;border-radius:8px;padding:8px 10px;margin-top:7px;font-size:.61rem;color:#fde68a;line-height:1.5;}
.api-notice a{color:#fbbf24;text-decoration:underline;cursor:pointer;}
</style>
</head>
