/* ══════════════════════════════════════════
   CALENDAR — TODAS AS MATÉRIAS
══════════════════════════════════════════ */
let calYear=new Date().getFullYear(),calMonth=new Date().getMonth();
const MONTH_NAMES=['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
const DAY_NAMES_SHORT=['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];

function renderCalendar(){
  const today=new Date();const todayY=today.getFullYear(),todayM=today.getMonth(),todayD=today.getDate();
  document.getElementById('calMonthTitle').textContent=`${MONTH_NAMES[calMonth]} ${calYear}`;
  const g=document.getElementById('calGrid');g.innerHTML='';
  DAY_NAMES_SHORT.forEach(d=>{const el=document.createElement('div');el.className='cal-dayname';el.textContent=d;g.appendChild(el);});
  const firstDOW=new Date(calYear,calMonth,1).getDay();
  const daysInMonth=new Date(calYear,calMonth+1,0).getDate();
  const studied=getStudiedDays();const streakDays=getStreakDays();
  for(let i=0;i<firstDOW;i++){const el=document.createElement('div');el.className='cal-cell empty';g.appendChild(el);}
  for(let d=1;d<=daysInMonth;d++){
    const dateStr=`${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const dow=new Date(calYear,calMonth,d).getDay();
    const dayId=DOW_TO_ID[dow];
    const schedItems=getScheduleForDay(dayId);
    const el=document.createElement('div');el.className='cal-cell';
    const isToday=(calYear===todayY&&calMonth===todayM&&d===todayD);
    if(isToday)el.classList.add('today');
    if(streakDays.includes(dateStr))el.classList.add('streak-day');
    else if(studied.includes(dateStr))el.classList.add('studied');
    const numEl=document.createElement('div');numEl.className='cal-cell-num';numEl.textContent=d;el.appendChild(numEl);
    const itemsEl=document.createElement('div');itemsEl.className='cal-items';
    // SHOW ALL ITEMS — no limit!
    schedItems.forEach(item=>{
      const chip=document.createElement('div');
      const chipCls=DOT_TO_CHIP[item.dot]||'chip-custom';
      chip.className=`cal-item-chip ${chipCls}`;
      chip.textContent=item.title.replace(/[\u{1F1E0}-\u{1F1FF}]{2}/gu,'').replace(/🇺🇸|🇯🇵|🇰🇷|🎓|📐/g,'').trim();
      chip.title=item.title;
      itemsEl.appendChild(chip);
    });
    el.appendChild(itemsEl);
    g.appendChild(el);
  }
}
function calPrev(){calMonth--;if(calMonth<0){calMonth=11;calYear--;}renderCalendar();}
function calNext(){calMonth++;if(calMonth>11){calMonth=0;calYear++;}renderCalendar();}

