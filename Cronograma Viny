function analyzeSuggestions(){
  const mats=getMats();const scores={};mats.forEach(m=>{scores[m]=0;});
  for(let w=1;w<=5;w++){const d=JSON.parse(localStorage.getItem('tracker_w'+w)||'null');if(!d)continue;mats.forEach((m,i)=>{const row=d[i];if(!row||!row.aulas)return;row.aulas.forEach(a=>{if(a.feito)scores[m]=(scores[m]||0)+1;});});}
  const sorted=Object.entries(scores).sort((a,b)=>a[1]-b[1]);if(!sorted.length)return;
  const [matName,count]=sorted[0];const name=getProfileName();
  const box=document.getElementById('suggestionBox');const txt=document.getElementById('suggestionText');
  if(count===0){txt.innerHTML=`<strong>${name}</strong>, você ainda não estudou <strong>${matName}</strong>. Que tal começar hoje? 💪`;box.classList.remove('hidden-box');}
  else if(count<3){txt.innerHTML=`<strong>${name}</strong>, você estudou <strong>${matName}</strong> poucas vezes. Bora revisar? 📖`;box.classList.remove('hidden-box');}
  else{box.classList.add('hidden-box');}
}
