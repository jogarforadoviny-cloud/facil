const DEFAULT_CONS=[{char:'ㄱ',rom:'g/k',ini:0},{char:'ㄴ',rom:'n',ini:2},{char:'ㄷ',rom:'d/t',ini:3},{char:'ㄹ',rom:'r/l',ini:5},{char:'ㅁ',rom:'m',ini:6},{char:'ㅂ',rom:'b/p',ini:7},{char:'ㅅ',rom:'s',ini:9},{char:'ㅇ',rom:'—',ini:11},{char:'ㅈ',rom:'j',ini:12},{char:'ㅊ',rom:'ch',ini:14},{char:'ㅋ',rom:'k',ini:15},{char:'ㅌ',rom:'t',ini:16},{char:'ㅍ',rom:'p',ini:17},{char:'ㅎ',rom:'h',ini:18}];
const DEFAULT_VOGS=[{char:'ㅏ',rom:'a',med:0},{char:'ㅑ',rom:'ya',med:1},{char:'ㅓ',rom:'eo',med:2},{char:'ㅕ',rom:'yeo',med:3},{char:'ㅗ',rom:'o',med:4},{char:'ㅛ',rom:'yo',med:5},{char:'ㅜ',rom:'u',med:6},{char:'ㅠ',rom:'yu',med:7},{char:'ㅡ',rom:'eu',med:8},{char:'ㅣ',rom:'i',med:9}];
function getHgCons(){return JSON.parse(localStorage.getItem('hg_cons')||JSON.stringify(DEFAULT_CONS));}
function getHgVogs(){return JSON.parse(localStorage.getItem('hg_vogs')||JSON.stringify(DEFAULT_VOGS));}
function saveHgCons(c){localStorage.setItem('hg_cons',JSON.stringify(c));}
function saveHgVogs(v){localStorage.setItem('hg_vogs',JSON.stringify(v));}
let sC=null,sV=null,curSyl='',krVoice=null;
function detectKrVoice(){
  if(!('speechSynthesis' in window))return;
  const tryLoad=()=>{const vs=speechSynthesis.getVoices();krVoice=vs.find(v=>v.lang.startsWith('ko'))||null;const st=document.getElementById('speechStatus');if(st)st.textContent=krVoice?`🔊 Voz: ${krVoice.name}`:(vs.length?'':'');};
  speechSynthesis.onvoiceschanged=tryLoad;tryLoad();
}
function speakText(txt,rate){
  if(!txt||!('speechSynthesis' in window))return;
  speechSynthesis.cancel();
  const u=new SpeechSynthesisUtterance(txt);u.lang='ko-KR';u.rate=rate||0.78;u.pitch=1.1;
  if(krVoice)u.voice=krVoice;
  speechSynthesis.speak(u);
}
function speakHangul(){speakText(curSyl);}
function speakCustomHangul(){const txt=document.getElementById('hangulTestInput').value.trim();if(!txt){alert('Digite algo para ouvir.');return;}speakText(txt,0.75);}
function buildHangulKeys(){
  const cons=getHgCons(),vogs=getHgVogs();
  const cEl=document.getElementById('hangulConsoantes');cEl.innerHTML='';cons.forEach((c,i)=>{cEl.appendChild(makeHgKey(c,'con',i));});
  const vEl=document.getElementById('hangulVogais');vEl.innerHTML='';vogs.forEach((v,i)=>{vEl.appendChild(makeHgKey(v,'vog',i));});
}
function makeHgKey(letter,type,idx){
  const b=document.createElement('button');b.className='hangul-key';b.dataset.type=type;b.dataset.idx=idx;b.dataset.char=letter.char;b.dataset.rom=letter.rom;b.dataset.ini=letter.ini||0;b.dataset.med=letter.med||0;
  b.innerHTML=`<span class="hk-main">${letter.char}</span><span class="hk-rom">${letter.rom}</span>`;
  b.onclick=()=>{
    if(type==='con'){sC=idx;document.querySelectorAll('#hangulConsoantes .hangul-key').forEach(x=>x.classList.remove('selected'));}
    else{sV=idx;document.querySelectorAll('#hangulVogais .hangul-key').forEach(x=>x.classList.remove('selected'));}
    b.classList.add('selected');combineHG();
  };
  return b;
}
function combineHG(){
  const btn=document.getElementById('hangulSpeakBtn');
  if(sC===null||sV===null){document.getElementById('hangulSyllable').textContent='?';document.getElementById('hangulComboLabel').textContent='Selecione ① e ②';curSyl='';btn.disabled=true;return;}
  const cons=getHgCons(),vogs=getHgVogs();const c=cons[sC],v=vogs[sV];
  const ini=parseInt(c.ini)||0,med=parseInt(v.med)||0;
  const code=0xAC00+(ini*21+med)*28;curSyl=String.fromCodePoint(code);
  document.getElementById('hangulSyllable').textContent=curSyl;
  document.getElementById('hangulComboLabel').textContent=`${c.char}(${c.rom}) + ${v.char}(${v.rom}) = ${curSyl}`;
  btn.disabled=false;speakText(curSyl);
}
function clearHangul(){
  sC=null;sV=null;curSyl='';
  document.querySelectorAll('.hangul-key').forEach(b=>b.classList.remove('selected'));
  document.getElementById('hangulSyllable').textContent='?';document.getElementById('hangulComboLabel').textContent='Selecione ① e ②';
  document.getElementById('hangulSpeakBtn').disabled=true;
  if('speechSynthesis' in window)speechSynthesis.cancel();
}
function deleteHangulKey(el){
  const type=el.dataset.type,idx=parseInt(el.dataset.idx);
  if(type==='con'){const cons=getHgCons();cons.splice(idx,1);saveHgCons(cons);if(sC===idx)sC=null;}
  else{const vogs=getHgVogs();vogs.splice(idx,1);saveHgVogs(vogs);if(sV===idx)sV=null;}
  buildHangulKeys();clearHangul();
}
function openHangulAddModal(){document.getElementById('hgChar').value='';document.getElementById('hgRom').value='';document.getElementById('hgIdx').value='0';document.getElementById('hangulAddModal').classList.remove('hidden');setTimeout(()=>document.getElementById('hgChar').focus(),100);}
function closeHangulAddModal(){document.getElementById('hangulAddModal').classList.add('hidden');}
function confirmAddHangulLetter(){
  const type=document.getElementById('hgType').value,ch=document.getElementById('hgChar').value.trim(),rom=document.getElementById('hgRom').value.trim(),idx=parseInt(document.getElementById('hgIdx').value)||0;
  if(!ch||!rom){alert('Preencha o caractere e a romanização.');return;}
  if(type==='con'){const cons=getHgCons();cons.push({char:ch,rom:rom,ini:idx});saveHgCons(cons);}
  else{const vogs=getHgVogs();vogs.push({char:ch,rom:rom,med:idx});saveHgVogs(vogs);}
  buildHangulKeys();closeHangulAddModal();
}
