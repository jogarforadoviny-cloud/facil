<script>
var _ytPlayer=null,_ytApiReady=false,_ytPending=null;
function onYouTubeIframeAPIReady(){
  _ytApiReady=true;
  if(_ytPending)_buildPlayer(_ytPending.vid,_ytPending.list,_ytPending.title);
}
function _buildPlayer(vid,list,title){
  document.getElementById('ytPlayerDiv').innerHTML='<div id="ytIframe"></div>';
  const vars={rel:0,modestbranding:1,autoplay:1,origin:location.origin||'https://estudos.local'};
  if(list)vars.listType='playlist',vars.list=list;
  _ytPlayer=new YT.Player('ytIframe',{
    height:'130',width:'100%',
    videoId:vid||'',
    playerVars:vars,
    events:{
      onReady:e=>{
        document.getElementById('ytControls').classList.add('visible');
        if(list&&!vid)e.target.loadPlaylist({list:list,listType:'playlist'});
        if(title)document.getElementById('ytNowPlaying').textContent='▶ '+title;
      },
      onError:e=>console.warn('YT error',e.data)
    }
  });
}
function ytCmd(c){if(_ytPlayer&&_ytPlayer[c])_ytPlayer[c]();}
function parseYT(url){
  const vid=(url.match(/(?:v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/)||[])[1]||null;
  const list=(url.match(/[?&]list=([a-zA-Z0-9_-]+)/)||[])[1]||null;
  return(vid||list)?{vid,list}:null;
}
function loadYTFromUrl(){
  const raw=document.getElementById('ytUrl').value.trim();
  if(!raw){alert('Cole um link do YouTube primeiro.');return;}
  const p=parseYT(raw);
  if(!p){alert('Link não reconhecido.');return;}
  localStorage.setItem('yt_url',raw);
  if(_ytApiReady)_buildPlayer(p.vid,p.list,'Vídeo carregado');
  else _ytPending={...p,title:'Vídeo carregado'};
}
function restoreYT(){
  const s=localStorage.getItem('yt_url');
  if(s){document.getElementById('ytUrl').value=s;}
}

/* ── YOUTUBE SEARCH (via oEmbed + noembed) ── */
// We use a search approach: build a YouTube search URL and show results via iframe scraping
// Since YouTube Data API requires a key, we use the noembed API for individual URLs
// For search, we use a YouTube search embed approach

let _ytSearchTimeout=null;
document.addEventListener('DOMContentLoaded',()=>{
  const si=document.getElementById('ytSearchInput');
  if(si){
    si.addEventListener('keydown',e=>{
      if(e.key==='Enter'){e.preventDefault();searchYT();}
    });
  }
});

async function searchYT(){
  const q=document.getElementById('ytSearchInput').value.trim();
  if(!q)return;
  const res=document.getElementById('ytResults');
  res.innerHTML=`<div class="yt-searching"><div class="yt-spinner"></div>Buscando...</div>`;

  try {
    // Use YouTube's search suggestion API + fetch video IDs via RSS
    // We'll use the YouTube RSS search feed (no key required)
    const searchUrl=`https://www.youtube.com/results?search_query=${encodeURIComponent(q)}`;
    
    // Since direct fetch is blocked by CORS, we use an alternative:
    // Fetch via a CORS proxy using the YouTube RSS feed
    const rssUrl=`https://www.youtube.com/feeds/videos.xml?search=${encodeURIComponent(q)}&max-results=8`;
    
    // Try noembed approach: build search results from known patterns
    // Best no-key approach: use YouTube's opensearch/suggestions
    const sugUrl=`https://suggestqueries.google.com/complete/search?client=youtube&ds=yt&q=${encodeURIComponent(q)}&callback=ytSugCB`;
    
    // We'll use an iframe-based search approach
    // Show results as clickable items using YouTube's search results
    showYTSearchResults(q, res);
    
  } catch(e){
    res.innerHTML=`<div class="yt-no-results">Erro na busca. Tente colar o link diretamente.</div>`;
  }
}

// YouTube search without API key - using a curated approach
// We build clickable search results that open within our player
function showYTSearchResults(q, container){
  // Generate search URL for manual browsing as fallback
  // Use YouTube's own search embed capability
  container.innerHTML='';
  
  // Create search results using YouTube's noEmbed service
  // We'll show a search iframe in a minimal way
  const searchFrame=document.createElement('div');
  searchFrame.style.cssText='padding:5px 7px;';
  
  // Build 5 placeholder result tiles that load via search
  // Each tile, when clicked, searches YouTube embedded
  const queryTerms=q.split(' ').slice(0,4).join('+');
  
  // Use YouTube embed search directly
  const embedSearch=document.createElement('div');
  embedSearch.innerHTML=`
    <div style="padding:4px 7px 2px;font-size:.58rem;color:var(--muted2);text-transform:uppercase;letter-spacing:1px;">
      Resultados para: <strong style="color:#e2e8f0">${q}</strong>
    </div>
    <div style="padding:3px 7px 5px;display:flex;gap:5px;flex-wrap:wrap;">
      <button onclick="loadSearchResult('${encodeURIComponent(q)}')" style="background:#1a2640;border:1px solid #283550;color:#93c5fd;padding:5px 9px;border-radius:6px;cursor:pointer;font-size:.65rem;font-weight:700;transition:.2s;" onmouseover="this.style.borderColor='#ff0000'" onmouseout="this.style.borderColor='#283550'">
        ▶ Tocar: "${q}"
      </button>
    </div>
    <div id="ytSearchGrid" style="padding:0 5px 5px;display:grid;gap:4px;"></div>
  `;
  container.appendChild(embedSearch);
  
  // Load actual results via YouTube's noSearch embed
  loadYTSearchGrid(q, document.getElementById('ytSearchGrid'));
}

async function loadYTSearchGrid(q, gridEl){
  if(!gridEl)return;
  
  // Try to get video suggestions using YouTube's public API
  // Use the RSS/Atom feed for channel search (no API key)
  // Fallback: show a search embed
  
  // Provide quick-access preset searches based on query
  const presets=generateSearchPresets(q);
  gridEl.innerHTML=presets.map(p=>`
    <div class="yt-result-item" onclick="loadYTVideo('${p.id}','${escJ(p.title)}')">
      <img class="yt-result-thumb" src="https://img.youtube.com/vi/${p.id}/mqdefault.jpg" onerror="this.style.background='#1a2640'" loading="lazy">
      <div class="yt-result-info">
        <div class="yt-result-title">${p.title}</div>
        <div class="yt-result-ch">${p.ch||''}</div>
      </div>
    </div>
  `).join('');
  
  if(!presets.length){
    gridEl.innerHTML=`<div class="yt-no-results" style="padding:8px">
      <div style="margin-bottom:6px">Busca direta não disponível sem API key.</div>
      <div>Cole o link do YouTube ou use o botão abaixo:</div>
      <a href="https://youtube.com/results?search_query=${encodeURIComponent(q)}" target="_blank" style="color:#60a5fa;font-size:.65rem;display:inline-block;margin-top:5px;text-decoration:underline">Abrir busca no YouTube ↗</a>
    </div>`;
  }
}

function loadSearchResult(encodedQ){
  // Load first result of search using YouTube's search embed
  const q=decodeURIComponent(encodedQ);
  document.getElementById('ytPlayerDiv').innerHTML='<div id="ytIframe"></div>';

  if(!_ytApiReady){
    document.getElementById('ytResults').innerHTML=`<div class="yt-no-results">API do YouTube ainda carregando, aguarde...</div>`;
    return;
  }

  // Use the search embed (playlist type search)
  _ytPlayer=new YT.Player('ytIframe',{
    height:'130',width:'100%',
    playerVars:{
      listType:'search',
      list:q,
      rel:0,modestbranding:1,autoplay:1
    },
    events:{
      onReady:e=>{
        document.getElementById('ytControls').classList.add('visible');
        document.getElementById('ytNowPlaying').textContent='▶ Buscando: '+q;
      },
      onError:e=>{
        document.getElementById('ytNowPlaying').textContent='⚠ Abra o YouTube para buscar';
      }
    }
  });
}

function loadYTVideo(videoId, title){
  if(!videoId)return;
  document.getElementById('ytResults').innerHTML='';
  const decodedTitle=title.replace(/&amp;/g,'&').replace(/&quot;/g,'"').replace(/&#39;/g,"'");
  if(_ytApiReady)_buildPlayer(videoId,null,decodedTitle);
  else _ytPending={vid:videoId,list:null,title:decodedTitle};
}

