function handleCtxAction(){
  if(_ctxType==='sched'){if(!_ctxEl)return;if(confirm(`Excluir "${_ctxEl.dataset.title}"?`)){_ctxEl.remove();saveSchedule();}}
  else if(_ctxType==='hangul'){if(!_ctxEl)return;deleteHangulKey(_ctxEl);}
  hideCtx();
}

