  </div>
  <div class="lab-grid">

    <div class="kanji-card lab-grid-full">
      <div class="kanji-badge">漢字 · Kanji do Dia</div>
      <div class="kanji-symbol" id="kanjiChar">一</div>
      <div class="kanji-info">
        <div class="kanji-item"><label>Significado</label><div class="val" id="kanjiSig">Um</div></div>
        <div class="kanji-item"><label>Leitura On</label><div class="val" id="kanjiOn">イチ・イツ</div><div class="roma" id="kanjiOnR">Ichi / Itsu</div></div>
        <div class="kanji-item"><label>Leitura Kun</label><div class="val" id="kanjiKun">ひと・つ</div><div class="roma" id="kanjiKunR">hito / -tsu</div></div>
        <div class="kanji-item"><label>JLPT</label><div class="val" id="kanjiJlpt">N5</div></div>
