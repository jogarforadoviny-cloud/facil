function getLevel(){return Math.floor(getXP()/XP_PER_LEVEL)+1;}
function getXPInLevel(){return getXP()%XP_PER_LEVEL;}
function addXP(amount){
  const prev=getLevel();
  setXP(getXP()+amount);
  const next=getLevel();
  renderGameBar();
  showXPFlash('+'+amount+' XP');
  if(next>prev)setTimeout(()=>showLevelUp(next),650);
}
