let jpVoice=null;
function detectJpVoice(){
  if(!('speechSynthesis' in window))return;
  const tryLoad=()=>{const vs=speechSynthesis.getVoices();jpVoice=vs.find(v=>v.lang.startsWith('ja'))||null;};
  speechSynthesis.onvoiceschanged=tryLoad;tryLoad();
